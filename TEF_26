<style>.wheel{width:300px;height:300px;border:8px solid var(--gold);border-radius:50%;background:conic-gradient(#0a0f2c 0 120deg,#d4af37 120deg 240deg,#fff 240deg);margin:20px auto;transition:transform 3.5s cubic-bezier(.17,.67,.41,1)}</style></head>
